# Copy to `.env` and fill in. The `.env` file is gitignored.
# Generate a write-scoped token at https://huggingface.co/settings/tokens

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_USERNAME=your-username

# Optional: Neptune (only needed if `logging.backend=neptune`)
# NEPTUNE_API_TOKEN=

# Optional: Weights & Biases (only needed if `logging.backend=wandb`)
# WANDB_API_KEY=
